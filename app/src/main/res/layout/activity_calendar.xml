<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <!-- أزرار التبديل (يومي، أسبوعي، شهري) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        app:elevation="2dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnDaily"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toggle_active"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="يومي"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnWeekly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toggle_inactive"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="أسبوعي"
            android:textAlignment="center"
            android:textColor="@color/text_grey"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnMonthly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toggle_inactive"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="شهري"
            android:textAlignment="center"
            android:textColor="@color/text_grey"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnYearly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_toggle_inactive"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="سنوي"
            android:textAlignment="center"
            android:textColor="@color/text_grey"
            android:textStyle="bold"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- شريط التنقل (للأسبوعي والشهري) -->
    <LinearLayout
        android:id="@+id/layoutNavHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="السابق"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tvPeriodName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="الفترة"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="التالي"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>

    <com.example.studntapp.SwipeNavLayout
        android:id="@+id/swipeNav"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 1. العرض اليومي (التقويم العادي والقائمة) -->
        <LinearLayout
            android:id="@+id/viewDaily"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- كتلة التقويم الشهري (تظهر في وضع "شهري" فقط) -->
            <LinearLayout
                android:id="@+id/calBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- اسم الشهر (التنقّل بالسحب يمين/يسار) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/tvDailyMonth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- تقويم شهري قابل للتمرير الأفقي بين الأشهر، بنقاط أحداث -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/monthPager"
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:background="@color/surface_white" />

            <!-- مقبض الطيّ/التوسعة (سحب أو نقر) -->
            <FrameLayout
                android:id="@+id/calExpandHandle"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:background="@color/surface_white"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="40dp"
                    android:layout_height="5dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_chip_unselected" />
            </FrameLayout>

            </LinearLayout>
            <!-- نهاية كتلة التقويم -->

            <!-- بطاقة اليوم المحدّد: كبيرة + الأحداث بداخلها (وضع "يومي" فقط) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/dayCard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDayCardYM"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ink_muted"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvDayCardNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ink"
                                android:textSize="58sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDayCardWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="14dp"
                        android:background="@color/line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حصص اليوم"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDayEvents"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="8dp"
                        android:clipToPadding="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvDailyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp"
                android:text="حصص اليوم"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDaily"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="20dp" />
        </LinearLayout>

        <!-- 2. العرض الأسبوعي (تنقّل الأسابيع بالسحب يمين/يسار) -->
        <ScrollView
            android:id="@+id/viewWeekly"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_light"
            android:fillViewport="true"
            android:layoutDirection="rtl"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/weeklyGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">
                <!-- سيتم توليده برمجياً -->
            </LinearLayout>
        </ScrollView>

        <!-- 3. العرض الشهري (شبكة 7 أيام) -->
        <ScrollView
            android:id="@+id/viewMonthly"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_light"
            android:fillViewport="true"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/monthlyGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="7"
                android:layoutDirection="rtl"
                android:padding="4dp">
                <!-- سيتم توليده برمجياً -->
            </GridLayout>
        </ScrollView>

        <!-- 4. العرض السنوي: ViewPager2 (سحب أصلي موثوق + انزلاق بطاقة) -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewYearly"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/canvas"
            android:visibility="gone" />

    </com.example.studntapp.SwipeNavLayout>
</LinearLayout>