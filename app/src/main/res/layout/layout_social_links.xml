<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center">

    <ImageButton
        android:id="@+id/btnSocialWhatsapp"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginHorizontal="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="واتساب"
        android:padding="8dp"
        android:src="@drawable/ic_phone"
        app:tint="#25D366" />

    <ImageButton
        android:id="@+id/btnSocialFacebook"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginHorizontal="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="فيسبوك"
        android:padding="8dp"
        android:src="@drawable/ic_account"
        app:tint="#1877F2" />

    <ImageButton
        android:id="@+id/btnSocialEmail"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginHorizontal="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="البريد الإلكتروني"
        android:padding="8dp"
        android:src="@drawable/ic_email"
        app:tint="#EA4335" />

    <ImageButton
        android:id="@+id/btnSocialWebsite"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginHorizontal="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="الموقع الإلكتروني"
        android:padding="8dp"
        android:src="@drawable/ic_website"
        app:tint="?attr/colorPrimary" />
</LinearLayout>
