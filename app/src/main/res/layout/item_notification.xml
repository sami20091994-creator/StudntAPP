<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNotif"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:layoutDirection="rtl"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- شريط جانبي يظهر فقط للإشعار غير المقروء -->
        <View
            android:id="@+id/viewUnreadStrip"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/gold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- نقطة غير مقروء -->
                <View
                    android:id="@+id/dotUnread"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_unread_dot" />

                <TextView
                    android:id="@+id/tvNotifTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="عنوان الإشعار"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNotifBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="محتوى الإشعار يظهر هنا بشكل مفصل..."
                android:textColor="@color/ink_muted"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvNotifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="منذ 5 دقائق"
                android:textColor="@color/ink_faint"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
