<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:layoutDirection="rtl">

    <!-- ===== المحتوى الرئيسي ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/canvas">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="@color/indigo"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/indigo"
                app:titleTextColor="@color/white"
                app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                android:layoutDirection="rtl" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- حاوية محتوى كل شاشة -->
        <FrameLayout
            android:id="@+id/activity_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/appbar"
            android:background="@color/canvas"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/bottom_content_padding" />

        <!-- ===== الشريط السفلي العائم ===== -->
        <FrameLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_alignParentBottom="true"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- خلفية الشريط -->
            <LinearLayout
                android:id="@+id/barBackground"
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_bar_height"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_bottom_bar"
                android:elevation="8dp"
                android:orientation="horizontal"
                android:layoutDirection="rtl">

                <!-- الجدول -->
                <LinearLayout
                    android:id="@+id/tab_schedule"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/icon_schedule"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tab_schedule" />
                    <TextView
                        android:id="@+id/label_schedule"
                        style="@style/BottomNavTabText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="الجدول"
                        android:textColor="@color/white" />
                </LinearLayout>

                <!-- المواد -->
                <LinearLayout
                    android:id="@+id/tab_materials"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/icon_materials"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tab_materials" />
                    <TextView
                        android:id="@+id/label_materials"
                        style="@style/BottomNavTabText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="المواد"
                        android:textColor="@color/white" />
                </LinearLayout>

                <!-- فجوة الزر المركزي -->
                <View
                    android:layout_width="72dp"
                    android:layout_height="match_parent" />

                <!-- التقارير -->
                <LinearLayout
                    android:id="@+id/tab_reports"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/icon_reports"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tab_reports" />
                    <TextView
                        android:id="@+id/label_reports"
                        style="@style/BottomNavTabText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="التقارير"
                        android:textColor="@color/white" />
                </LinearLayout>

                <!-- الملف -->
                <LinearLayout
                    android:id="@+id/tab_profile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/icon_profile"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tab_profile" />
                    <TextView
                        android:id="@+id/label_profile"
                        style="@style/BottomNavTabText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="الملف"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>

            <!-- قطع دائري لإيهام الفجوة -->
            <View
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_fab_cutout"
                android:elevation="10dp" />

            <!-- زر الرئيسية العائم -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fab_home"
                android:layout_width="@dimen/fab_size"
                android:layout_height="@dimen/fab_size"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="6dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="16dp"
                app:cardBackgroundColor="@color/indigo_dark"
                app:cardCornerRadius="31dp"
                app:cardElevation="16dp"
                app:strokeColor="@color/gold"
                app:strokeWidth="3dp"
                app:rippleColor="@color/gold_soft">

                <ImageView
                    android:id="@+id/icon_home"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home_fab" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/label_home"
                style="@style/BottomNavTabText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="7dp"
                android:elevation="20dp"
                android:text="الرئيسية"
                android:textColor="@color/gold" />
        </FrameLayout>

    </RelativeLayout>

    <!-- ===== القائمة الجانبية (المزيد) ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="288dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:fitsSystemWindows="true"
        android:background="@color/surface"
        android:layoutDirection="rtl"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu_student"
        app:itemIconTint="@color/indigo"
        app:itemTextColor="@color/ink"
        app:itemBackground="@drawable/bg_nav_item"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemIconSize="24dp"
        app:itemHorizontalPadding="20dp"
        app:itemIconPadding="16dp"
        app:elevation="8dp" />

</androidx.drawerlayout.widget.DrawerLayout>
