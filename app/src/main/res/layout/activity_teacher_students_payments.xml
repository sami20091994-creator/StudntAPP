<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/canvas"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="3dp"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_nav_payments"
                app:tint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مدفوعات الطلاب حسب المادة"
                android:textColor="@color/ink"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSearchStudent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_search_input"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:hint="ابحث عن اسم الطالب..."
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_faint"
            android:textSize="14sp"
            app:drawableTint="@color/ink_faint" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSubjectsGroups"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp" />

</LinearLayout>
