<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:layoutDirection="rtl">

    <!-- Chat List View -->
    <LinearLayout
        android:id="@+id/layoutChatList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Header -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_white"
            app:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الرسائل والدردشة"
                    android:textColor="@color/primary_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="right" />

                <!-- Search Bar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:background="@color/background_light">

                    <EditText
                        android:id="@+id/etSearchChats"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="12dp"
                        android:hint="ابحث عن محادثة..."
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:inputType="text"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_light"
                        android:gravity="center_vertical"
                        app:drawableTint="@color/text_light" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Conversations List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface_white"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />
    </LinearLayout>

    <!-- Chat Room View -->
    <LinearLayout
        android:id="@+id/layoutChatRoom"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/background_light">

        <!-- Chat Header -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_white"
            app:elevation="4dp">

            <androidx.appcompat.widget.Toolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:contentInsetStart="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Back Button -->
                    <ImageButton
                        android:id="@+id/btnBackToList"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/primary_blue" />

                    <!-- User Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tvRoomName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="متصل الآن"
                            android:textColor="@color/success_green"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Search Messages Button -->
                    <ImageButton
                        android:id="@+id/btnToggleSearchMessages"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/text_grey" />
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

            <!-- Search Messages Field (Hidden by Default) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <EditText
                    android:id="@+id/etSearchMessages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="بحث في الرسائل..."
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:maxLines="1"
                    android:inputType="text"
                    android:gravity="center_vertical" />
            </androidx.cardview.widget.CardView>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Messages List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="12dp" />

        <!-- Message Input Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            app:elevation="8dp">

            <!-- Attach File Button -->
            <ImageButton
                android:id="@+id/btnAttachFile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/text_grey" />

            <!-- Message Input Field -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:background="@color/background_light">

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="اكتب رسالتك..."
                    android:maxLines="4"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark" />
            </androidx.cardview.widget.CardView>

            <!-- Action Container (Record Audio / Send Message) -->
            <FrameLayout
                android:id="@+id/btnActionContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_send_button">

                <!-- Record Audio Button -->
                <Button
                    android:id="@+id/btnRecordAudio"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:text="🎤"
                    android:textSize="18sp" />

                <!-- Send Message Button -->
                <ImageButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Clear Text Button -->
            <ImageButton
                android:id="@+id/btnClearText"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone"
                app:tint="@color/text_light" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
