<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.StudntAPP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- الهوية الأساسية -->
        <item name="colorPrimary">@color/indigo</item>
        <item name="colorPrimaryVariant">@color/indigo_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- الثانوية -->
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold</item>
        <item name="colorOnSecondary">@color/indigo_deep</item>
        <!-- الأسطح -->
        <item name="android:colorBackground">@color/canvas</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorError">@color/error_red</item>
        <!-- شريط الحالة والتنقل -->
        <item name="android:statusBarColor">@color/indigo</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/canvas</item>
    </style>

    <style name="Theme.StudntAPP" parent="Base.Theme.StudntAPP" />

    <style name="Widget.CalendarView.Custom" parent="android:Widget.CalendarView">
    </style>
</resources>
