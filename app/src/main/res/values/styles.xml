<resources>
    <style name="ShapeAppearanceOverlay.App.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="contentPadding">16dp</item>
        <item name="rippleColor">@color/indigo_soft</item>
    </style>

    <style name="App.SectionTitle" parent="">
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="App.Caption" parent="">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/ink_muted</item>
    </style>

    <style name="App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/indigo</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="BottomNavTabText" parent="">
        <item name="android:textSize">10.5sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
